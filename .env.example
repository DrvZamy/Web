# Mode lokal: development. Di Netlify NODE_ENV otomatis production saat runtime.
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# WA admin (format internasional tanpa tanda +)
ADMIN_WHATSAPP=6283830287126

# Opsional: email yang boleh menjadi superadmin pertama bila database belum memiliki superadmin.
# Paket ini juga memiliki akun superadmin bawaan; detail ada di ADMIN-LOGIN.txt.
BOOTSTRAP_ADMIN_EMAIL=

# WAJIB: buat nilai acak panjang dan berbeda untuk setiap secret.
JWT_SECRET=ganti-dengan-random-panjang-minimal-32-karakter
CSRF_SECRET=ganti-dengan-random-lain-minimal-32-karakter
PLUGIN_API_KEY=ganti-dengan-api-key-random-panjang
PLUGIN_SERVER_ID=minefive-main

# AI MineFive Assistant — simpan API key hanya di Environment Variables Netlify.
# Jangan menulis key asli di source code, app.js, atau repository publik.
MINERVAX_API_KEY=sk-mvx-5d26bd50c12649652141048538c9277ff222fcad4a50c842
MINERVAX_BASE_URL=https://ai.minervax.dev
MINERVAX_MODEL=mvx/claude-opus-4-8
# auto mencoba endpoint Anthropic lalu OpenAI. Nilai lain: anthropic / openai.
MINERVAX_API_STYLE=auto

# Status server memakai public ping Java + Bedrock dan heartbeat plugin.
# Set true hanya jika ingin mematikan public ping dan memakai heartbeat plugin saja.
DISABLE_PUBLIC_SERVER_PING=false

# Penyimpanan Netlify Blobs. Nama default ini boleh dibiarkan.
NETLIFY_DATA_STORE=minefive-data
NETLIFY_FILE_STORE=minefive-files

# Discord Application/Bot (opsional, diperlukan untuk notifikasi dan tombol interaktif)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=1523872049259348059
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_ADMIN_ROLE_IDS=

# Email reset password (opsional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MineFiveID <noreply@minefive.my.id>

# Hanya diperlukan apabila scripts/make-admin.js dijalankan dari komputer lokal
# untuk mengubah data pada situs Netlify yang sudah online.
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
